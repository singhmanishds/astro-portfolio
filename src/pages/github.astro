---
import Layout from '@/layouts/Layout.astro';
// Import the React component that contains the page content
// import GitHubPageContent from '@/components/page-content/github-page-content';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
// Removed conflicting Github import, using Construction icon
import { Construction, ExternalLink } from 'lucide-react'; // Import icons
---

<Layout title="GitHub Contributions - Under Construction">
  <div class="container mx-auto px-4 py-16 md:py-24 flex items-center justify-center min-h-[60vh]">
    <Card className="max-w-xl w-full shadow-lg border border-border/50 bg-card rounded-xl p-8 text-center">
      <CardHeader className="p-0 mb-4">
        <Construction className="h-12 w-12 mx-auto text-accent mb-4" />
        <CardTitle className="text-2xl font-semibold text-primary mb-2">GitHub Section Under Construction</CardTitle>
        <CardDescription className="text-base text-muted-foreground">
          This section is currently being developed. In the meantime, feel free to visit my GitHub profile directly.
        </CardDescription>
      </CardHeader>
      <Button variant="outline" asChild className="mt-6 hover:bg-accent hover:text-accent-foreground border-primary/50 hover:border-accent transition-all duration-300 focus-visible:ring-accent shadow-sm hover:shadow-md transform hover:-translate-y-0.5">
        <a href="https://github.com/singhmanishds" target="_blank" rel="noopener noreferrer">
          Visit My GitHub Profile <ExternalLink className="ml-2 h-4 w-4" />
        </a>
      </Button>
      {/* Removed the GitHubPageContent component as it's commented out */}
      {/* <GitHubPageContent client:load /> */}
    </Card>
  </div>
</Layout>
