
---
// src/pages/github.astro
import Layout from '@/layouts/Layout.astro';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'; // ShadCN components
import { Button } from '@/components/ui/button';
import { Github, Construction } from 'lucide-react'; // Import icons
---

<Layout title="GitHub - Under Construction">
  <div class="container mx-auto px-4 py-16 flex items-center justify-center min-h-[calc(100vh-var(--header-height)-10rem)]">
    <Card className="max-w-xl w-full shadow-lg border border-border/50 bg-card rounded-xl p-8 text-center">
      <CardHeader className="p-0 mb-6">
        <Construction className="h-16 w-16 text-accent mx-auto mb-4" />
        <CardTitle className="text-2xl font-semibold text-primary mb-2">GitHub Section Under Construction</CardTitle>
        <CardDescription className="text-muted-foreground text-lg">
          I'm currently organizing my public repositories. Please check back soon!
        </CardDescription>
      </CardHeader>
      <Button variant="outline" asChild>
        <a href="https://github.com/singhmanishds" target="_blank" rel="noopener noreferrer">
          <Github className="mr-2 h-4 w-4" /> Visit My GitHub Profile
        </a>
      </Button>
    </Card>
  </div>
</Layout>
